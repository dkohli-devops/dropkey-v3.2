# ─────────────────────────────────────────
# DropKey v3.2 — Environment Variables
# COPY this file to .env and fill values
# kabhi bhi .env GitHub pe push mat karna!
# ─────────────────────────────────────────

# APP
DROPKEY_APP_NAME=DropKey
DROPKEY_ENVIRONMENT=development
DROPKEY_DEBUG=true
DROPKEY_SECRET_KEY=your-super-secret-key-change-this

# SERVER
DROPKEY_HOST=0.0.0.0
DROPKEY_PORT=8000
DROPKEY_WORKERS=1

# DATABASE
DROPKEY_DATABASE_ENABLED=true
DROPKEY_DATABASE_URL=postgresql://user:password@localhost:5432/dropkey_db

# REDIS
DROPKEY_REDIS_ENABLED=true
DROPKEY_REDIS_URL=redis://localhost:6379/0

# JWT
DROPKEY_JWT_SECRET_KEY=your-jwt-secret-key-change-this
DROPKEY_JWT_ALGORITHM=HS256
DROPKEY_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
DROPKEY_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# LOGGING
DROPKEY_LOG_LEVEL=INFO

# SENTRY (optional)
DROPKEY_SENTRY_DSN=